{
  "version": "1.0",
  "name": "TestDesign",
  "theme": {
    "colors": {
      "primary": "#3B82F6",
      "secondary": "#F3F4F6"
    },
    "fontFamily": {
      "sans": "Inter"
    }
  },
  "components": [
    {
      "id": "card-1",
      "name": "Card",
      "type": "frame",
      "layout": {
        "mode": "vertical",
        "width": { "type": "fixed", "value": 320 },
        "padding": { "top": 16, "right": 16, "bottom": 16, "left": 16 },
        "gap": 8,
        "mainAxisAlign": "start",
        "crossAxisAlign": "stretch"
      },
      "style": {
        "fills": [{ "type": "solid", "color": "#FFFFFF" }],
        "borderRadius": { "topLeft": 8, "topRight": 8, "bottomRight": 8, "bottomLeft": 8 },
        "effects": [
          { "type": "drop-shadow", "offset": { "x": 0, "y": 1 }, "radius": 2, "spread": 0, "color": "rgba(0,0,0,0.05)" }
        ]
      },
      "children": [
        {
          "id": "title-1",
          "name": "Title",
          "type": "text",
          "text": {
            "content": "Card Title",
            "fontSize": 18,
            "fontWeight": 600,
            "textAlign": "left"
          },
          "style": {
            "fills": [{ "type": "solid", "color": "#111827" }]
          },
          "children": []
        },
        {
          "id": "desc-1",
          "name": "Description",
          "type": "text",
          "text": {
            "content": "This is a card component generated by fig2r.",
            "fontSize": 14,
            "fontWeight": 400
          },
          "style": {
            "fills": [{ "type": "solid", "color": "#6B7280" }]
          },
          "children": []
        }
      ]
    }
  ],
  "assets": []
}
